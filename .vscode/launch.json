{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "mighty-core: UI debug host (lldb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/mighty-core-ui",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "lldb",
      "preLaunchTask": "mighty-core: build (Debug)"
    },
    {
      "name": "mighty-core: Debug host check (lldb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/mighty-core-host-check",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "lldb",
      "preLaunchTask": "mighty-core: build (Debug)"
    },
    {
      "name": "mighty-core: Run all tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/tests/mmc-tests",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "lldb",
      "preLaunchTask": "mighty-core: build (Debug)"
    },
    {
      "name": "mighty-core: Debug tests (lldb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/tests/mmc-tests",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": true,
      "MIMode": "lldb",
      "preLaunchTask": "mighty-core: build (Debug)"
    },
    {
      "name": "mighty-core: Run single test (lldb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/tests/mmc-tests",
      "args": ["--gtest_filter=${input:gtestFilter}"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "lldb",
      "preLaunchTask": "mighty-core: build (Debug)"
    }
  ],
  "inputs": [
    {
      "id": "gtestFilter",
      "type": "promptString",
      "description": "GoogleTest filter (e.g. Scheduler.* or MightyMusicCore.TickCallbackFires)",
      "default": "Scheduler.*"
    }
  ]
}
